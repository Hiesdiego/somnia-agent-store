# Prophecy Companion relayer/indexer production template.
# Keep this file as an example only. Real values belong in your host secrets manager.

SOMNIA_RPC_URL=https://api.infra.testnet.somnia.network

# Vault-authorized relayer wallet. Do not reuse deployer or admin keys.
RELAYER_PRIVATE_KEY=
AUTOPILOT_VAULT_ADDRESS=0x553CEE1B1aA3cD44E25Ff64Bf4dAf2b8E4C6eDC2
AUTOPILOT_RELAYER_FEE_STT=0.20
AUTOPILOT_SCAN_FROM_BLOCK=398888944
AUTOPILOT_LOG_CHUNK_SIZE=900
AUTOPILOT_DAEMON_INTERVAL_MS=60000
AUTOPILOT_MAX_EXECUTIONS_PER_SCAN=5

# Durable state files when not using Supabase. Mount these on persistent storage.
AUTOPILOT_STATE_FILE=.autopilot-relayer-state.json
AUTOPILOT_INDEXER_STATE_FILE=.autopilot-indexer-state.json
AUTOPILOT_RUN_LOG_FILE=.autopilot-runs.jsonl

# Optional app context endpoint. In production this should be your deployed PC app URL.
COMPANION_APP_CONTEXT_ENDPOINT=https://your-prophecy-companion-domain.example/api/market-context
COMPANION_APP_DISCOVERY_ENDPOINT=https://your-prophecy-companion-domain.example/api/market-discovery

# Autonomy memory + learning store.
AUTONOMY_STORE_MODE=supabase
AUTONOMY_LOCAL_STATE_FILE=.autonomy-state.json
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=public

# Trigger policy.
AUTONOMY_HISTORY_LIMIT=200
AUTONOMY_TRIGGER_COOLDOWN_MS=900000
AUTONOMY_ODDS_JUMP_BPS=1200
AUTONOMY_ODDS_JUMP_WINDOW_MINUTES=30
AUTONOMY_VOLUME_SPIKE_MULTIPLIER=2
AUTONOMY_SENTIMENT_DIVERGENCE_THRESHOLD=0.35
AUTONOMY_WHALE_FLOW_THRESHOLD=0.6
AUTONOMY_MIN_CONFIDENCE_TO_EXECUTE=0.58
AUTONOMY_MIN_EDGE_TO_EXECUTE=0.06
AUTONOMY_REQUIRE_SIGNAL_FOR_CADENCE=1
AUTONOMY_MIN_CONFIDENCE_FOR_CADENCE=0.5
AUTONOMY_MIN_EDGE_FOR_CADENCE=0.025
AUTONOMY_THESIS_REVISION_MIN_DELTA=0.025
AUTONOMY_LEARNING_RATE=0.15
AUTONOMY_MAX_SNAPSHOTS_PER_MISSION=1000

AUTONOMY_OUTCOME_SYNC_URL=
AUTONOMY_OUTCOME_SYNC_API_KEY=
