# Somnia agent wallet key (used by somnia-agent-kit)
PRIVATE_KEY=

# Optional explicit RPC (depends on your target)
SOMNIA_RPC_URL=https://api.infra.testnet.somnia.network

# Official Somnia Agents platform and base-agent IDs.
SOMNIA_AGENT_PLATFORM_ADDRESS=0x037Bb9C718F3f7fe5eCBDB0b600D607b52706776
SOMNIA_LLM_AGENT_ID=12847293847561029384
SOMNIA_JSON_API_AGENT_ID=
SOMNIA_WEBSITE_PARSE_AGENT_ID=

# LLM provider: openai, anthropic, or groq.
# Groq is used through an OpenAI-compatible base URL/proxy path.
COMPANION_LLM_PROVIDER=openai

# LLM keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Optional default model/persona controls
COMPANION_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GROQ_MODEL=llama-3.3-70b-versatile
COMPANION_SYSTEM_PROMPT=You are Prophecy Companion. Provide concise, evidence-based probability analysis.
COMPANION_EVENT_URL=https://prophecy.social/event/14776
COMPANION_DEFAULT_ASK=Given the event details and resolution criteria, what is the likely outcome now?
COMPANION_EXTRA_CONTEXT=
COMPANION_FETCH_TIMEOUT_MS=12000
COMPANION_VISIBLE_TEXT_LIMIT=8000
COMPANION_PAGE_CONTEXT_LIMIT=24000
COMPANION_MARKET_FACT_LIMIT=120
COMPANION_SOURCE_LIMIT=10
COMPANION_USER_AGENT=Mozilla/5.0 (compatible; ProphecyCompanion/1.0; +https://prophecy.social)
COMPANION_DEBUG=0

# Broader evidence gathering. This helps the companion use more than Prophecy odds.
COMPANION_ENABLE_WEB_RESEARCH=1
COMPANION_RESEARCH_QUERY_LIMIT=4
COMPANION_RESEARCH_RESULT_LIMIT=8
COMPANION_FETCH_RESEARCH_PAGES=1
COMPANION_RESEARCH_PAGE_LIMIT=3
COMPANION_RESEARCH_TIMEOUT_MS=10000
COMPANION_RESEARCH_PAGE_TEXT_LIMIT=1500

# Optional OpenAI-compatible endpoint override.
# Direct Groq endpoint:
# COMPANION_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# Local proxy endpoint:
# COMPANION_OPENAI_BASE_URL=http://localhost:8787/v1
COMPANION_OPENAI_BASE_URL=

COMPANION_SOMNIA_AGENT_NAME=Prophecy Companion Agent
COMPANION_SOMNIA_AGENT_DESCRIPTION=Analyzes Somnia Prophecy markets with structured probability, confidence, evidence, and reasoning.
COMPANION_SOMNIA_AGENT_METADATA_URI=ipfs://prophecy-companion-agent-v1
COMPANION_SOMNIA_AGENT_CAPABILITIES=prediction-market-analysis,web-research,probability-estimation,structured-json,prophecy-social
GROQ_PROXY_PORT=8787

# Autopilot relayer
# RELAYER_PRIVATE_KEY should be the private key for the vault-authorized relayer wallet.
RELAYER_PRIVATE_KEY=
# Current SAS v0.1 testnet vault deployment.
AUTOPILOT_VAULT_ADDRESS=0xE7F454628390d1DD95De3D2cEB10fBFc27a9d041
AUTOPILOT_RELAYER_FEE_STT=0.20
AUTOPILOT_SCAN_FROM_BLOCK=392885823
AUTOPILOT_LOG_CHUNK_SIZE=900
AUTOPILOT_DAEMON_INTERVAL_MS=60000
AUTOPILOT_MAX_EXECUTIONS_PER_SCAN=5
AUTOPILOT_STATE_FILE=.autopilot-relayer-state.json

# Optional: if the Prophecy Companion app is running, the relayer can reuse its market-context API.
COMPANION_APP_CONTEXT_ENDPOINT=http://localhost:3010/api/market-context
COMPANION_APP_DISCOVERY_ENDPOINT=http://localhost:3010/api/market-discovery

# Autonomy memory + learning store.
# If SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are set, store mode defaults to "supabase".
AUTONOMY_STORE_MODE=local
AUTONOMY_LOCAL_STATE_FILE=.autonomy-state.json
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=public

# Trigger + thesis policy tuning.
AUTONOMY_HISTORY_LIMIT=200
AUTONOMY_TRIGGER_COOLDOWN_MS=900000
AUTONOMY_ODDS_JUMP_BPS=1200
AUTONOMY_ODDS_JUMP_WINDOW_MINUTES=30
AUTONOMY_VOLUME_SPIKE_MULTIPLIER=2
AUTONOMY_SENTIMENT_DIVERGENCE_THRESHOLD=0.35
AUTONOMY_WHALE_FLOW_THRESHOLD=0.6
AUTONOMY_MIN_CONFIDENCE_TO_EXECUTE=0.58
AUTONOMY_MIN_EDGE_TO_EXECUTE=0.06
AUTONOMY_REQUIRE_SIGNAL_FOR_CADENCE=1
AUTONOMY_MIN_CONFIDENCE_FOR_CADENCE=0.5
AUTONOMY_MIN_EDGE_FOR_CADENCE=0.025
AUTONOMY_THESIS_REVISION_MIN_DELTA=0.025
AUTONOMY_LEARNING_RATE=0.15
AUTONOMY_MAX_SNAPSHOTS_PER_MISSION=1000

# Optional resolved-outcome sync endpoint for feedback learning.
AUTONOMY_OUTCOME_SYNC_URL=
AUTONOMY_OUTCOME_SYNC_API_KEY=

# Agent E.V.E governance rails
EVE_AGENT_NAME=Agent E.V.E
EVE_SOMNIA_AGENT_NAME=EVE Autonomous Governor
EVE_SOMNIA_AGENT_ID=12847293847561029384
EVE_AGENT_REQUESTER_ADDRESS=0x0d33089cae750fbff1ae75ce97e49b005303eebd
EVE_SOMNIA_AGENT_DESCRIPTION=Private SAS governance operator that audits marketplace listings, verifies healthy agents, quarantines failing agents, and patrols protocol role policies.
EVE_SOMNIA_AGENT_METADATA_URI=ipfs://sas-eve-private-governor
EVE_SOMNIA_AGENT_CAPABILITIES=sas-governance,audit,verification,quarantine,role-policy,private-operator
EVE_GROQ_API_KEY=
EVE_GROQ_MODEL=openai/gpt-oss-20b
EVE_DRY_RUN=0
EVE_LOOP_INTERVAL_MS=120000
EVE_REPORT_COOLDOWN_MS=3600000
EVE_ENABLE_ALLOWLIST_TOGGLES=1
EVE_ENABLE_CANONICAL_LISTING_GUARDIAN=1
EVE_ENABLE_SOMNIA_LINK_VERIFIER=1
EVE_ENABLE_EXECUTION_HEALTH_SENTINEL=1
EVE_ENABLE_PRICE_SANITY=1
EVE_ENABLE_METADATA_FETCH=1
EVE_ENABLE_BUILDER_REPUTATION=1
EVE_ENABLE_TREASURY_RESERVE_WATCH=1
EVE_ENABLE_ROLE_DRIFT_WATCHER=1
EVE_ALLOW_DUPLICATE_DEPRECATE=1
EVE_MAX_MUTATIONS_PER_CYCLE=6
EVE_ACTION_COOLDOWN_MS=900000
EVE_METADATA_FETCH_TIMEOUT_MS=8000
EVE_EXECUTION_RECENT_LIMIT=12
EVE_MAX_PENDING_EXECUTION_AGE_MS=900000
EVE_MAX_EXECUTION_FAILURE_RATE_BPS=5000
EVE_MIN_AGENT_PRICE_WEI=1
EVE_MAX_AGENT_PRICE_WEI=10000000000000000000
EVE_MAX_AGENT_FEE_TO_RUNTIME_BPS=20000
EVE_MIN_TREASURY_WEI=0
EVE_MIN_EXECUTOR_RESERVE_WEI=0
EVE_EXPECTED_PROTOCOL_OWNER=
EVE_ADMIN_TIMELOCK_ADDRESS=
EVE_IPFS_GATEWAY=https://ipfs.io/ipfs
EVE_VERIFY_HEALTHY_STREAK=2
EVE_UNVERIFY_FAILURE_STREAK=2
EVE_ALLOW_DEPRECATE=1
EVE_DEPRECATE_FAILURE_STREAK=5
EVE_DEPRECATE_REQUIRE_UNVERIFIED=1
EVE_PROTECTED_AGENT_IDS=
EVE_ALLOWLIST_AGENT_IDS=
