NEXT_PUBLIC_PRIVY_APP_ID=your_production_privy_app_id

# Public SAS deployment addresses consumed by Prophecy Companion.
NEXT_PUBLIC_SAS_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SAS_BILLING_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SAS_EXECUTOR_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SAS_AUTONOMY_V4_ADDRESS=0x0000000000000000000000000000000000000000
